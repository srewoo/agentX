# StockPilot Backend Configuration
# Copy this to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8020

# Simple API key auth (leave empty to disable auth - fine for localhost)
API_KEY=

# SQLite database path
SQLITE_PATH=./stockpilot.db

# Redis (optional - caching works without it)
REDIS_URL=redis://localhost:6379

# LLM API Keys (at least one required for AI features)
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# Default LLM provider (gemini | openai | claude)
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash

# Signal engine defaults
DEFAULT_ALERT_INTERVAL_MINUTES=30
