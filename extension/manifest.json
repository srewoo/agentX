{
  "manifest_version": 3,
  "name": "agentX",
  "version": "1.1.0",
  "description": "AI-powered trading copilot for Indian stock markets (NSE/BSE)",
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "activeTab",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:8020/*",
    "http://127.0.0.1:8020/*",
    "https://*.moneycontrol.com/*",
    "https://*.tickertape.in/*",
    "https://*.tradingview.com/*",
    "https://*.screener.in/*",
    "https://*.nseindia.com/*",
    "https://*.bseindia.com/*",
    "https://*.zerodha.com/*",
    "https://*.kite.zerodha.com/*",
    "https://*.upstox.com/*",
    "https://*.groww.in/*",
    "https://*.angelone.in/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.moneycontrol.com/*",
        "https://*.tickertape.in/*",
        "https://*.tradingview.com/*",
        "https://*.screener.in/*",
        "https://*.nseindia.com/*",
        "https://*.bseindia.com/*",
        "https://*.zerodha.com/*",
        "https://*.kite.zerodha.com/*",
        "https://*.upstox.com/*",
        "https://*.groww.in/*",
        "https://*.angelone.in/*"
      ],
      "js": [
        "content/mount.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "agentX"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
